{
  "name": "times-pos",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "TIMES POS — point-of-sale for Thai watch shop. React + Supabase, bundles to a single static index.html via Vite.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:deploy": "node scripts/test-subpath-deploy.mjs",
    "build:verify": "npm run build && npm run test:deploy",
    "lint": "eslint . --ext .js,.jsx,.cjs --max-warnings=9999",
    "lint:fix": "eslint . --ext .js,.jsx,.cjs --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,css}\" \"tests/**/*.{js,jsx}\" \"*.{json,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,css}\" \"tests/**/*.{js,jsx}\""
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "@zxing/browser": "^0.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.26",
    "postcss": "^8.4.47",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.13",
    "vite": "^5.4.8",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-singlefile": "^2.0.2",
    "vitest": "^2.1.2",
    "workbox-window": "^7.4.1"
  }
}
